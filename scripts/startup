#!/bin/sh
#
# /bin/sh replacement for startup, by Spectrum
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Public port: auto-detects TLS or plain telnet (sniff port).
# Mudlet "secure" connections and plain telnet both work on this port.
# PORT ASSIGNMENTS ARE FIXED:
#   8890  plain telnet   (positional argument — always plain, never TLS)
#   9890  TLS telnet     (--tls-port; Mudlet "connect securely")
#   18890 WebSocket      (--ws-loopback; ws:// only; wss:// not yet implemented)
telnet_port=8890
tls_port=9890
tls_cert=/etc/letsencrypt/live/ackmud.com/fullchain.pem
tls_key=/etc/letsencrypt/live/ackmud.com/privkey.pem
ws_port=18890

# TLS certificate setup: use Let's Encrypt certs if present, otherwise fall
# back to a self-signed certificate generated by the cert script.
if [ ! -f "$tls_cert" ] || [ ! -f "$tls_key" ]; then
    tls_cert="$SCRIPT_DIR/../data/tls/cert.pem"
    tls_key="$SCRIPT_DIR/../data/tls/key.pem"
    "$SCRIPT_DIR/../data/tls/generate-certs.sh" --cert "$tls_cert" --key "$tls_key"
fi

# set up
cd ../reports
if [ -f shutdown.txt ]; then rm -f shutdown.txt; fi

mkdir -p /home/ftp/pub/webpage

ACK_WEB_PORT=8080 ../web/web_who_server.py >>../log/webserver.log 2>&1 &
webserver_pid=$!

cleanup_webserver()
{
  if kill -0 "$webserver_pid" 2>/dev/null; then
    kill "$webserver_pid"
  fi
}

trap cleanup_webserver EXIT

cd ../area

# allow cores
ulimit -c 50000
# stack limit
ulimit -s 1500

mkdir -p ../cores

renice +5 -p $$

# loop indefinately
while :
do
  # find a logfile

  index=1000
  while :
  do
    logfile=../log/$index.log
    if [ ! -e $logfile ]; then break; fi
    index=$((index+1))
  done

  # snapshot the executable before launching so we have the exact binary
  # that ran if a core dump is produced
  ack_snapshot=$(mktemp ../cores/ack.XXXXXX)
  cp ../src/ack "$ack_snapshot"

  # run the mud
  ../src/ack $telnet_port --tls-port $tls_port --ws-loopback $ws_port --tls-cert $tls_cert --tls-key $tls_key >$logfile 2>&1

  # If do_hotreboot() ran, it wrote a snapshot of the binary it exec'd;
  # that is more accurate than our startup-time snapshot, so prefer it.
  if [ -f ../cores/ack.hotreboot ]; then
    rm -f "$ack_snapshot"
    ack_snapshot=../cores/ack.hotreboot
  fi

  # collect all core dumps into a single ../cores/<timestamp>/ directory
  coredir=""
  for corefile in core core.*; do
    if [ -f "$corefile" ]; then
      if [ -z "$coredir" ]; then
        coredir=../cores/$(date +%Y%m%d_%H%M%S)_$$
        mkdir -p "$coredir"
        mv "$ack_snapshot" "$coredir/ack"
        ack_snapshot=""
      fi
      mv "$corefile" "$coredir/"
    fi
  done
  if [ -n "$coredir" ]; then
    echo "startup: core dump(s) saved to $coredir" >>$logfile
  fi

  # discard whichever snapshot was not consumed by a core
  rm -f "$ack_snapshot" ../cores/ack.hotreboot

  # shutdown?

cd ../reports

  if [ -e shutdown.txt ]; then
    echo "startup: shutting down" >>$logfile
    exit 1
  fi

cd ../area
  
  # sleep, so if we fail on boot we don't get massive looping
  sleep 10
done
