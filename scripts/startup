#!/bin/sh
#
# /bin/sh replacement for startup, by Spectrum
#

# Public port: auto-detects TLS or plain telnet (sniff port).
# Mudlet "secure" connections and plain telnet both work on this port.
port=8890
# Internal plain-telnet port (bound to all interfaces; can be firewalled from outside).
# Required as the server's first positional argument.
plain_port=4000
# Dedicated TLS-only port (public, all interfaces)
tls_port=8880
tls_cert=/etc/letsencrypt/live/ackmud.com/fullchain.pem
tls_key=/etc/letsencrypt/live/ackmud.com/privkey.pem
# WebSocket loopback port (127.0.0.1 only; nginx TLS proxy forwards wss://ackmud.com:9890 here)
ws_port=18890

# set up
cd ../reports
if [ -f shutdown.txt ]; then rm -f shutdown.txt; fi

mkdir -p /home/ftp/pub/webpage

ACK_WEB_PORT=8080 ../web/web_who_server.py >>../log/webserver.log 2>&1 &
webserver_pid=$!

cleanup_webserver()
{
  if kill -0 "$webserver_pid" 2>/dev/null; then
    kill "$webserver_pid"
  fi
}

trap cleanup_webserver EXIT

cd ../area

# allow cores
ulimit -c 50000
# stack limit
ulimit -s 1500

mkdir -p ../cores

renice +5 -p $$

# loop indefinately
while :
do
  # find a logfile

  index=1000
  while :
  do
    logfile=../log/$index.log
    if [ ! -e $logfile ]; then break; fi
    index=$((index+1))
  done

  # snapshot the executable before launching so we have the exact binary
  # that ran if a core dump is produced
  ack_snapshot=$(mktemp ../cores/ack.XXXXXX)
  cp ../src/ack "$ack_snapshot"

  # run the mud
  ../src/ack $plain_port --sniff-port $port --ws-loopback $ws_port --tls-port $tls_port --tls-cert $tls_cert --tls-key $tls_key >$logfile 2>&1

  # collect any core dumps into ../cores/<timestamp>/
  for corefile in core core.*; do
    if [ -f "$corefile" ]; then
      coredir=../cores/$(date +%Y%m%d_%H%M%S)_$$
      mkdir -p "$coredir"
      mv "$corefile" "$coredir/"
      mv "$ack_snapshot" "$coredir/ack"
      ack_snapshot=""
      echo "startup: core dump saved to $coredir" >>$logfile
    fi
  done

  # no core dump — discard the snapshot
  rm -f "$ack_snapshot"

  # shutdown?

cd ../reports

  if [ -e shutdown.txt ]; then
    echo "startup: shutting down" >>$logfile
    exit 1
  fi

cd ../area
  
  # sleep, so if we fail on boot we don't get massive looping
  sleep 10
done
