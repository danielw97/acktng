#!/bin/sh
#
# /bin/sh replacement for startup, by Spectrum
#

# grab the port number
port=8890

# set up
cd ../reports
if [ -f shutdown.txt ]; then rm -f shutdown.txt; fi

mkdir -p /home/ftp/pub/webpage

../src/web_who_server.py >>../log/webserver.log 2>&1 &
webserver_pid=$!

cleanup_webserver()
{
  if kill -0 "$webserver_pid" 2>/dev/null; then
    kill "$webserver_pid"
  fi
}

trap cleanup_webserver EXIT

cd ../area

# allow cores
ulimit -c 50000
# stack limit
ulimit -s 1500

renice +5 -p $$

# loop indefinately
while :
do
  # find a logfile

  index=1000
  while :
  do
    logfile=../log/$index.log
    if [ ! -e $logfile ]; then break; fi
    index=$((index+1))
  done

  # run the mud
  ../src/ack $port >$logfile 2>&1

  # shutdown?

cd ../reports

  if [ -e shutdown.txt ]; then
    echo "startup: shutting down" >>$logfile
    exit 1
  fi

cd ../area
  
  # sleep, so if we fail on boot we don't get massive looping
  sleep 10
done
